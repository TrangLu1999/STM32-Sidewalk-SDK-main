            /* Failed to allocate buffer, return NULL pointer to indicate the failure */
            break;
        }

        /* Copy key material into RAM buffer. This step can be used to load the key from encrypted storage */
        memcpy(app_verification_key_ptr, app_verification_key, sizeof(*app_verification_key_ptr));
