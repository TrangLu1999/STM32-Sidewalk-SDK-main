const ed25519_pub_key_t * aim_load_application_verification_key(void)
{
    /**
     * @note This is a sample implementation showing how to load the firmware
     *       verification from a storage and provide it to the AIM. While this
     *       example uses the key store directly on flash and a pointer to
     *       that flash  location can be returned immediately, dynamic memory
     *       allocation and copying to the RAM buffer is used here intentionally
     *       to demonstrate the strategy of handling key material that is stored
     *       in a storage that is not directly accessible via a pointer (e.g.,
     *       encrypted key storage).
     *
     * @warning The code below is suitable for demonstration purposes only. Do
     *          not use it in production. To keep the boot and OTA processes
     *          secure, the verification key shall at least be immutable (e.g.,
     *          stored in OTP area). Key encryption is optional here since the
     *          validation process uses Ed25519 EdDSA and only the public key
     *          is used by AIM. Even if this key is extracted from the device,
     *          it's still not suitable for signing firmware images.
     */

    UTILS_ENTER_CRITICAL_SECTION();

